# Model Configuration
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENAI_API_KEY=your_openai_key_here  # for CLIP and Whisper
LLAMA_MODEL_PATH=./models/llama2  # Path to LLaMA 2 model

# Paths Configuration
MOVIE_DATA_DIR=./data/movies
CACHE_DIR=./data/cache
MODEL_DIR=./data/models
TEMP_DIR=./data/temp
INDEX_DIR=./data/index  # For scene indexing
CLIP_OUTPUT_DIR=./data/clips  # For generated clips

# Processing Configuration
MAX_CLIP_LENGTH=120  # seconds
MIN_CLIP_LENGTH=5    # seconds
MAX_PARALLEL_TASKS=4
CACHE_EXPIRY=3600   # seconds
GPU_MEMORY_LIMIT=0.9  # 90% of available GPU memory
CPU_MEMORY_LIMIT=0.8  # 80% of available CPU memory

# Search Configuration
SEARCH_THRESHOLD=0.75
MAX_RESULTS=10
CONTEXT_WINDOW=30   # seconds
SEMANTIC_SIMILARITY_THRESHOLD=0.85
CACHE_MAX_SIZE=10737418240  # 10GB in bytes

# Clip Generation Configuration
TARGET_FPS=30
TARGET_RESOLUTION=1920x1080
QUALITY_PRESET=high  # low, medium, high
ENABLE_TRANSITIONS=true
ENABLE_STABILIZATION=true
TRANSITION_DURATION=0.5  # seconds

# Resource Management
MIN_FREE_MEMORY=2048  # MB
MAX_CONCURRENT_TASKS=3
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/sainma.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_ROTATION=1d  # Rotate logs daily

# API Configuration
API_HOST=localhost
API_PORT=8000
API_DEBUG=true
API_WORKERS=4
API_TIMEOUT=30  # seconds
